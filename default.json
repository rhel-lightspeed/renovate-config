{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":gitSignOff", "schedule:weekends"],
  "labels": ["dependencies"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "platformAutomerge": false,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  },
  "tekton": {
    "enabled": true
  },
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": ["7-day cooldown for all updates"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": ["Disable auto-merge for all updates"],
      "matchPackageNames": ["*"],
      "automerge": false
    },
    {
      "description": ["Group all non-major dependency updates"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major"
    },
    {
      "description": ["Disable Python version updates (pinned per repo)"],
      "matchDepNames": ["python"],
      "enabled": false
    }
  ]
}
